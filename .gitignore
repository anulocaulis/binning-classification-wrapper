# Ignore compiled singularity/apptainer containers
# these can be very large files and are better stored outside the repo
*.sif
*.simg

# Ignore Snakemake internal files and output directories
.snakemake/
binning_outputs/                    # All workflow outputs (bins, classifications, QC results)
multiqc_inputs/                     # MultiQC staging directory (symlinks to binning_outputs)
classification_outputs/
qc/
logs/                               # Workflow log files
slurm_logs/                          # SLURM job logs
data/                               # Input data (reads, etc.)
databases/                          # Reference databases (Kraken2, GTDB-Tk, etc.)
busco_downloads/                    # BUSCO lineage downloads

# Python and IDE
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/

# Log files
*.log
*.err
*.out
